  "placement_engine": {
    "philosophy": "Nature uses phyllotaxis. So do we.",
    "golden_angle_degrees": 137.5077640500378,
    "methods": {
      "GOLDEN_SPIRAL": {
        "description": "Fibonacci phyllotaxis \u2014 densest aperiodic packing",
        "seed_influence": "phase offset from interview depth_score",
        "attunement_gate": true,
        "use_for": [
          "trees",
          "rocks",
          "flora",
          "ruins"
        ]
      },
      "PERLIN_FIELD": {
        "description": "Fractal noise modulation over spiral candidates",
        "octaves": 4,
        "persistence": 0.5,
        "lacunarity": 2.0,
        "seed_influence": "full seed hash as noise seed",
        "use_for": [
          "moisture_patches",
          "moss",
          "nerve_growth"
        ]
      },
      "GAUSSIAN_ATTUNEMENT": {
        "description": "Existing system \u2014 ecological correctness",
        "use_for": [
          "species_selection",
          "placement_gate"
        ]
      },
      "COMBINED": {
        "description": "Spiral candidates filtered by Perlin then gated by Gaussian",
        "pipeline": [
          "GOLDEN_SPIRAL",
          "PERLIN_FIELD",
          "GAUSSIAN_ATTUNEMENT"
        ],
        "result": "ecologically correct, spatially inevitable, truly bespoke"
      }
    },
    "object_categories": {
      "flora": {
        "density": 0.8,
        "method": "COMBINED"
      },
      "geology": {
        "density": 0.3,
        "method": "GOLDEN_SPIRAL"
      },
      "fauna": {
        "density": 0.2,
        "method": "PERLIN_FIELD"
      },
      "remnant": {
        "density": 0.1,
        "method": "GAUSSIAN_ATTUNEMENT"
      },
      "relic": {
        "density": 0.05,
        "method": "GAUSSIAN_ATTUNEMENT"
      }
    }
  },
