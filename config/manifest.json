  "questionnaire": {
    "version": "1.0",
    "consent_note": "All questions optional. No PII collected. Your words stay in your vault.",
    "prompts": [
      {
        "id": "q1",
        "prompt": "Where are you right now?",
        "type": "choice",
        "options": {
          "city": {
            "biome_key": "NEON_CITY",
            "label": "In the city"
          },
          "nature": {
            "biome_key": "VERDANT",
            "label": "Somewhere natural"
          },
          "home": {
            "biome_key": "VOID",
            "label": "At home"
          },
          "between": {
            "biome_key": "RUINED",
            "label": "In between places"
          }
        },
        "default": "home"
      },
      {
        "id": "q2",
        "prompt": "What time of day does it feel like?",
        "type": "choice",
        "options": {
          "morning": {
            "ambient_intensity": 0.8,
            "label": "Morning"
          },
          "midday": {
            "ambient_intensity": 1.0,
            "label": "Midday"
          },
          "evening": {
            "ambient_intensity": 0.5,
            "label": "Evening"
          },
          "night": {
            "ambient_intensity": 0.2,
            "label": "Night"
          },
          "cant_tell": {
            "ambient_intensity": 0.4,
            "label": "Can't tell"
          }
        },
        "default": "evening"
      },
      {
        "id": "q3",
        "prompt": "How long have you been awake?",
        "type": "choice",
        "options": {
          "just_started": {
            "karma_baseline": 0.1,
            "label": "Just started my day"
          },
          "few_hours": {
            "karma_baseline": 0.3,
            "label": "A few hours"
          },
          "too_long": {
            "karma_baseline": 0.7,
            "label": "Too long"
          },
          "dont_know": {
            "karma_baseline": 0.5,
            "label": "I don't know"
          }
        },
        "default": "few_hours"
      },
      {
        "id": "q4",
        "prompt": "You feel more comfortable in...",
        "type": "choice",
        "options": {
          "open": {
            "spawn_radius": 60,
            "label": "Open space"
          },
          "enclosed": {
            "spawn_radius": 20,
            "label": "Enclosed space"
          },
          "either": {
            "spawn_radius": 40,
            "label": "Doesn't matter"
          }
        },
        "default": "either"
      },
      {
        "id": "q5",
        "prompt": "Something is on your mind. How heavy is it?",
        "type": "choice",
        "options": {
          "light": {
            "encounter_density": 0.1,
            "impact_rating": 2,
            "label": "Light"
          },
          "medium": {
            "encounter_density": 0.3,
            "impact_rating": 5,
            "label": "Medium"
          },
          "heavy": {
            "encounter_density": 0.6,
            "impact_rating": 7,
            "label": "Heavy"
          },
          "crushing": {
            "encounter_density": 0.9,
            "impact_rating": 9,
            "label": "Crushing"
          }
        },
        "default": "medium"
      },
      {
        "id": "q6",
        "prompt": "How do you move through the world today?",
        "type": "choice",
        "options": {
          "deliberately": {
            "camera_speed": 25.0,
            "karma_decay_rate": 0.15,
            "label": "Deliberately"
          },
          "quickly": {
            "camera_speed": 55.0,
            "karma_decay_rate": 0.03,
            "label": "Quickly"
          },
          "carefully": {
            "camera_speed": 20.0,
            "karma_decay_rate": 0.2,
            "label": "Carefully"
          },
          "not_sure": {
            "camera_speed": 40.0,
            "karma_decay_rate": 0.08,
            "label": "Not sure"
          }
        },
        "default": "not_sure"
      },
